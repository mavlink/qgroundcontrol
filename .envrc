# QGroundControl development environment
# Requires: direnv (https://direnv.net/)
# Run `direnv allow` after cloning to enable

# Inherit parent .envrc if exists
source_up_if_exists

# Python virtual environment
if [[ -d .venv ]]; then
    source .venv/bin/activate
elif [[ -d tools/.venv ]]; then
    source tools/.venv/bin/activate
fi

# Load build configuration as environment variables
if [[ -f tools/setup/read-config.sh ]]; then
    eval "$(./tools/setup/read-config.sh 2>/dev/null)" || true
fi

# Qt installation
if [[ -z "${QT_ROOT_DIR:-}" ]]; then
    QT_VERSION="${QT_VERSION:-6.8.3}"
    case "$(uname -s)" in
        Linux)
            QT_SEARCH_PATHS=(
                "$HOME/Qt/$QT_VERSION/gcc_64"
                "/opt/Qt/$QT_VERSION/gcc_64"
                "/usr/lib/qt6"
            )
            ;;
        Darwin)
            QT_SEARCH_PATHS=(
                "$HOME/Qt/$QT_VERSION/macos"
                "/opt/homebrew/opt/qt@6"
                "/usr/local/opt/qt@6"
            )
            ;;
    esac
    for qt_path in "${QT_SEARCH_PATHS[@]}"; do
        if [[ -d "$qt_path" ]]; then
            export QT_ROOT_DIR="$qt_path"
            PATH_add "$qt_path/bin"
            break
        fi
    done
fi

# Build directory
export BUILD_DIR="${BUILD_DIR:-build}"

# ccache (if available)
if has ccache; then
    export CCACHE_DIR="${CCACHE_DIR:-$HOME/.ccache}"
    export CMAKE_C_COMPILER_LAUNCHER=ccache
    export CMAKE_CXX_COMPILER_LAUNCHER=ccache
fi

# Helpful aliases via layout
layout_qgc() {
    PATH_add tools
    PATH_add .github/scripts
}
layout qgc
