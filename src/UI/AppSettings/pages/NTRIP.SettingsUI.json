{
    "version": 1,
    "groups": [
        {
            "component": "NtripConnectionStatus",
            "sectionName": "Connection Status",
            "keywords": "ntrip,rtk,connection status,corrections"
        },
        {
            "component": "NtripServerSettings",
            "sectionName": "Server Settings",
            "keywords": "ntrip server,rtk,caster,host,port,username,password,mountpoint"
        },
        {
            "component": "NtripMountpointBrowser",
            "sectionName": "Mountpoint Browser",
            "keywords": "mountpoint,browse,stream"
        },
        {
            "heading": "Options",
            "controls": [
                {
                    "setting": "ntripSettings.ntripWhitelist",
                    "placeholder": "e.g. 1005,1077,1087"
                }
            ]
        },
        {
            "heading": "UDP Forwarding",
            "controls": [
                {
                    "setting": "ntripSettings.ntripUdpForwardEnabled"
                },
                {
                    "setting": "ntripSettings.ntripUdpTargetAddress",
                    "enableWhen": "QGroundControl.settingsManager.ntripSettings.ntripUdpForwardEnabled.rawValue"
                },
                {
                    "setting": "ntripSettings.ntripUdpTargetPort",
                    "enableWhen": "QGroundControl.settingsManager.ntripSettings.ntripUdpForwardEnabled.rawValue"
                }
            ]
        }
    ]
}
