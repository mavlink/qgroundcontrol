{
    "version": 1,
    "fileType": "SettingsUI",
    "bindings": {
        "_appSettings": "QGroundControl.settingsManager.appSettings"
    },
    "groups": [
        {
            "heading": "General",
            "keywords": ["language", "locale", "color scheme", "dark mode", "theme", "palette", "follow me", "audio", "volume", "sound", "gstreamer", "debug level", "ui scale", "font size", "zoom", "save path", "storage", "reset", "clear settings", "factory reset"],
            "controls": [
                {
                    "setting": "appSettings.qLocaleLanguage",
                    "control": "combobox"
                },
                {
                    "setting": "appSettings.indoorPalette"
                },
                {
                    "setting": "appSettings.followTarget"
                },
                {
                    "setting": "appSettings.audioVolume",
                    "control": "slider",
                    "enableCheckbox": {
                        "checked": "!_appSettings.audioMuted.rawValue",
                        "onClicked": "{ if (enableCheckBoxChecked && _appSettings.audioVolume.rawValue <= 0) _appSettings.audioVolume.rawValue = 75; _appSettings.audioMuted.rawValue = !enableCheckBoxChecked }"
                    },
                    "button": {
                        "text": "Test",
                        "onClicked": "QGroundControl.testAudioOutput()",
                        "enabled": "!_appSettings.audioMuted.rawValue && _appSettings.audioVolume.rawValue > 0"
                    }
                },
                {
                    "setting": "appSettings.gstDebugLevel"
                },
                {
                    "setting": "appSettings.uiScalePercent",
                    "control": "scaler"
                },
                {
                    "setting": "appSettings.savePath",
                    "control": "browse",
                    "showWhen": "!ScreenTools.isMobile"
                },
                {
                    "setting": "appSettings.clearSettingsNextBoot"
                }
            ]
        },
        {
            "heading": "Vehicle Preferences",
            "keywords": ["firmware", "ardupilot", "px4", "vehicle", "multirotor", "fixed wing", "vtol", "rover", "sub"],
            "controls": [
                {
                    "setting": "appSettings.preferredFirmwareClass",
                    "control": "combobox"
                },
                {
                    "setting": "appSettings.preferredVehicleClass",
                    "control": "combobox"
                }
            ]
        },
        {
            "heading": "Units",
            "keywords": ["units", "metric", "imperial", "distance", "speed", "area", "temperature", "feet", "meters"],
            "showWhen": "QGroundControl.settingsManager.unitsSettings.userVisible",
            "controls": [
                {
                    "setting": "unitsSettings.horizontalDistanceUnits",
                    "control": "combobox"
                },
                {
                    "setting": "unitsSettings.verticalDistanceUnits",
                    "control": "combobox"
                },
                {
                    "setting": "unitsSettings.areaUnits",
                    "control": "combobox"
                },
                {
                    "setting": "unitsSettings.speedUnits",
                    "control": "combobox"
                },
                {
                    "setting": "unitsSettings.temperatureUnits",
                    "control": "combobox"
                }
            ]
        }
    ]
}
