{
    "version": 1,
    "fileType": "SettingsUI",
    "imports": [],
    "bindings": {
        "settingsManager": "QGroundControl.settingsManager",
        "logSettings": "settingsManager.logManagerSettings",
        "diskLoggingEnabledValue": "logSettings.diskLoggingEnabled.rawValue",
        "logSavePath": "settingsManager.appSettings.logSavePath"
    },
    "groups": [
        {
            "heading": "Save To Disk",
            "sectionName": "Save To Disk",
            "keywords": ["disk", "logging", "file", "flush", "save", "path", "compression", "rotation", "backup"],
            "controls": [
                { "setting": "logManagerSettings.diskLoggingEnabled" },
                { "setting": "logManagerSettings.diskLoggingMaxFileSizeMB", "enableWhen": "diskLoggingEnabledValue" },
                { "setting": "logManagerSettings.diskLoggingMaxBackupFiles", "enableWhen": "diskLoggingEnabledValue" },
                { "setting": "logManagerSettings.saveFormat" }
            ]
        },
        {
            "heading": "Log Viewer",
            "sectionName": "Log Viewer",
            "keywords": ["console", "buffer", "entries", "elapsed", "timestamp", "time", "gstreamer", "debug"],
            "controls": [
                { "setting": "appSettings.showAppLogTimestampAsElapsedTime" },
                { "setting": "appSettings.gstDebugLevel" }
            ]
        }
    ]
}
