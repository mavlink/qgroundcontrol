{
    "version": 1,
    "fileType": "SettingsUI",
    "groups": [
        {
            "component": "NtripConnectionSettings",
            "sectionName": "Connection",
            "keywords": [
                "ntrip",
                "rtk",
                "connection status",
                "corrections"
            ]
        },
        {
            "component": "NtripServerSettings",
            "sectionName": "Server Settings",
            "keywords": [
                "ntrip server",
                "rtk",
                "caster",
                "host",
                "port",
                "username",
                "password",
                "mountpoint"
            ]
        },
        {
            "component": "NtripMountpointBrowser",
            "sectionName": "Mountpoint Browser",
            "keywords": [
                "mountpoint",
                "browse",
                "stream"
            ]
        },
        {
            "heading": "GGA Position Reporting",
            "keywords": ["gga", "vrs", "nmea", "position", "network rtk", "ntrip"],
            "controls": [
                {
                    "setting": "ntripSettings.ntripGgaPositionSource"
                },
                {
                    "setting": "ntripSettings.ntripGgaIntervalSec"
                }
            ]
        },
        {
            "heading": "Options",
            "keywords": ["rtcm", "whitelist", "message filter", "ntrip"],
            "controls": [
                {
                    "setting": "ntripSettings.ntripWhitelist",
                    "placeholder": "e.g. 1005,1077,1087"
                }
            ]
        },
        {
            "heading": "UDP Forwarding",
            "keywords": ["udp forward", "relay", "corrections forward", "rtcm"],
            "controls": [
                {
                    "setting": "ntripSettings.ntripUdpForwardEnabled"
                },
                {
                    "setting": "ntripSettings.ntripUdpTargetAddress",
                    "enableWhen": "QGroundControl.settingsManager.ntripSettings.ntripUdpForwardEnabled.rawValue"
                },
                {
                    "setting": "ntripSettings.ntripUdpTargetPort",
                    "enableWhen": "QGroundControl.settingsManager.ntripSettings.ntripUdpForwardEnabled.rawValue"
                }
            ]
        },
        {
            "heading": "UDP RTCM Input",
            "keywords": ["udp rtcm"],
            "controls": [
                {
                    "setting": "ntripSettings.rtcmUdpInputEnabled"
                },
                {
                    "setting": "ntripSettings.rtcmUdpInputPort",
                    "enableWhen": "QGroundControl.settingsManager.ntripSettings.rtcmUdpInputEnabled.rawValue"
                },
                {
                    "setting": "ntripSettings.rtcmUdpValidate",
                    "enableWhen": "QGroundControl.settingsManager.ntripSettings.rtcmUdpInputEnabled.rawValue"
                }
            ]
        }
    ]
}
