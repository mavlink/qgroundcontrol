        {
            "title": "Dead Reckoning Failsafe",
            "keywords": [
                "dead reckoning",
                "gps loss",
                "navigation",
                "position estimate"
            ],
            "showWhen": "controller.vehicle.multiRotor && controller.parameterExists(-1, \"FS_DR_ENABLE\")",
            "controls": [
                {
                    "label": "Enabled",
                    "control": "toggleCheckbox",
                    "toggleCheckbox": {
                        "checked": "_drEnabled",
                        "onChecked": "_drEnable.rawValue = _drParamValueLand",
                        "onUnchecked": "_drEnable.rawValue = 0"
                    }
                },
                {
                    "param": "FS_DR_TIMEOUT",
                    "label": "Timeout",
                    "optional": true,
                    "showWhen": "_drEnabled"
                },
                {
                    "param": "FS_DR_ENABLE",
                    "label": "Action:",
                    "control": "radiogroup",
                    "raw": true,
                    "showWhen": "_drEnabled",
                    "options": [
                        {
                            "label": "Land",
                            "value": "_drParamValueLand",
                            "checked": "_drEnable.rawValue === _drParamValueLand"
                        },
                        {
                            "label": "RTL",
                            "value": "_drParamValueRtl",
                            "checked": "_drEnable.rawValue === _drParamValueRtl"
                        },
                        {
                            "label": "SmartRTL or RTL",
                            "value": "_drParamValueSmartRtlOrRtl",
                            "checked": "_drEnable.rawValue === _drParamValueSmartRtlOrRtl"
                        },
                        {
                            "label": "SmartRTL or Land",
                            "value": "_drParamValueSmartRtlOrLand",
                            "checked": "_drEnable.rawValue === _drParamValueSmartRtlOrLand"
                        },
                        {
                            "label": "Auto Land/Return or RTL",
                            "value": "_drParamValueAutoLandOrRtl",
                            "checked": "_drEnable.rawValue === _drParamValueAutoLandOrRtl"
                        }
                    ]
                },
                {
                    "control": "label",
                    "label": "Ignore failsafe if:",
                    "showWhen": "_fsOptionsAvailable && _drEnabled"
                },
                {
                    "param": "FS_OPTIONS",
                    "label": "Landing",
                    "control": "bitmaskCheckbox",
                    "bitMask": 8,
                    "indent": true,
                    "optional": true,
                    "showWhen": "_fsOptionsAvailable && _drEnabled"
                }
            ]
        },
        {
            "title": "Other Failsafe Options",
            "keywords": [
                "crash",
                "vibration",
                "gripper"
            ],
            "showWhen": "controller.vehicle.multiRotor",
            "controls": [
                {
                    "param": "FS_CRASH_CHECK",
                    "label": "Crash check failsafe",
                    "control": "checkbox"
                },
                {
                    "param": "FS_VIBE_ENABLE",
                    "label": "Vibration failsafe",
                    "control": "checkbox",
                    "optional": true
                },
                {
                    "param": "FS_OPTIONS",
                    "label": "Release gripper on any failsafe",
                    "control": "bitmaskCheckbox",
                    "bitMask": 32,
                    "optional": true,
                    "showWhen": "_fsOptionsAvailable"
                }
            ]
        },
        {
            "title": "Other Failsafe Options",
            "keywords": [
                "crash",
                "vibration",
                "gripper"
            ],
            "showWhen": "_roverFirmware",
            "controls": [
                {
                    "label": "Crash check failsafe",
                    "control": "toggleCheckbox",
                    "toggleCheckbox": {
                        "checked": "_roverCrashEnabled",
                        "onChecked": "_roverCrashCheck.rawValue = _roverCrashParamValueHold",
                        "onUnchecked": "_roverCrashCheck.rawValue = 0"
                    }
                },
                {
                    "param": "FS_CRASH_CHECK",
                    "label": "Action:",
                    "control": "radiogroup",
                    "raw": true,
                    "showWhen": "_roverCrashEnabled",
                    "options": [
                        {
                            "label": "Hold",
                            "value": "_roverCrashParamValueHold",
                            "checked": "_roverCrashCheck.rawValue === _roverCrashParamValueHold"
                        },
                        {
                            "label": "Hold and Disarm",
                            "value": "_roverCrashParamValueHoldAndDisarm",
                            "checked": "_roverCrashCheck.rawValue === _roverCrashParamValueHoldAndDisarm"
                        }
                    ]
                }
            ]
        }
    ]
}
