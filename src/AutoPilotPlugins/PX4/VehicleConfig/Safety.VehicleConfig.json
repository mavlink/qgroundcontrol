{
    "fileType": "VehicleConfig",
    "version": 1,
    "constants": {
        "_rtlLandDelayParamValueLandImmediately": 0,
        "_rtlLandDelayParamValueLoiterIndefinitely": -1,
        "_rtlLandDelayParamValueLoiterDefault": 60
    },
    "params": {
        "_cpDist": {
            "name": "CP_DIST",
            "required": true
        },
        "_fenceRadius": {
            "name": "GF_MAX_HOR_DIST",
            "required": true
        },
        "_fenceAlt": {
            "name": "GF_MAX_VER_DIST",
            "required": true
        },
        "_disarmLandDelay": {
            "name": "COM_DISARM_LAND",
            "required": true
        },
        "_landSpeedMCExists": {
            "name": "MPC_LAND_SPEED",
            "existsOnly": true
        },
        "_rtlLandDelay": {
            "name": "RTL_LAND_DELAY",
            "required": true
        }
    },
    "sections": [
        {
            "title": "Low Battery Failsafe",
            "keywords": [
                "battery",
                "voltage",
                "low battery",
                "critical battery",
                "emergency",
                "power"
            ],
            "image": "/qmlimages/LowBattery.svg",
            "controls": [
                {
                    "param": "COM_LOW_BAT_ACT",
                    "label": "Failsafe action",
                    "control": "combobox"
                },
                {
                    "param": "BAT_LOW_THR",
                    "label": "Battery warn level"
                },
                {
                    "param": "BAT_CRIT_THR",
                    "label": "Battery failsafe level"
                },
                {
                    "param": "BAT_EMERGEN_THR",
                    "label": "Battery emergency level"
                }
            ]
        },
        {
            "title": "Object Detection",
            "keywords": [
                "collision",
                "avoidance",
                "obstacle",
                "proximity",
                "distance"
            ],
            "image": "/qmlimages/ObjectAvoidance.svg",
            "controls": [
                {
                    "param": "CP_DIST",
                    "label": "Collision prevention minimum distance",
                    "control": "slider",
                    "enableCheckbox": {
                        "checked": "_cpDist.rawValue > 0",
                        "onClicked": "{ _cpDist.rawValue = enableCheckBoxChecked ? 5 : -1 }"
                    }
                },
                {
                    "setting": "flyViewSettings.showObstacleDistanceOverlay",
                    "label": "Show obstacle distance overlay",
                    "control": "checkbox"
                }
            ]
        },
        {
            "title": "RC/Joystick Loss Failsafe",
            "keywords": [
                "radio",
                "receiver",
                "transmitter",
                "rc loss",
                "joystick",
                "signal loss"
            ],
            "image": "/qmlimages/RCLoss.svg",
            "controls": [
                {
                    "param": "NAV_RCL_ACT",
                    "label": "Failsafe action",
                    "control": "combobox"
                },
                {
                    "param": "COM_RC_LOSS_T",
                    "label": "RC/joystick loss timeout"
                }
            ]
        },
        {
            "title": "Data Link Loss Failsafe",
            "keywords": [
                "telemetry",
                "link loss",
                "ground station",
                "gcs",
                "disconnect"
            ],
            "image": "/qmlimages/DatalinkLoss.svg",
            "controls": [
                {
                    "param": "NAV_DLL_ACT",
                    "label": "Failsafe action",
                    "control": "combobox"
                },
                {
                    "param": "COM_DL_LOSS_T",
                    "label": "Data link loss timeout"
                }
            ]
        },
        {
            "title": "Geofence Failsafe",
            "keywords": [
                "geofence",
                "boundary",
                "fence",
                "containment",
                "radius",
                "altitude",
                "breach"
            ],
            "image": "/qmlimages/GeoFence.svg",
            "controls": [
                {
                    "param": "GF_ACTION",
                    "label": "Action on breach",
                    "control": "combobox"
                },
                {
                    "param": "GF_MAX_HOR_DIST",
                    "label": "Max radius",
                    "control": "slider",
                    "enableCheckbox": {
                        "checked": "_fenceRadius.value > 0",
                        "onClicked": "{ _fenceRadius.value = enableCheckBoxChecked ? 100 : 0 }"
                    }
                },
                {
                    "param": "GF_MAX_VER_DIST",
                    "label": "Max altitude",
                    "control": "slider",
                    "enableCheckbox": {
                        "checked": "_fenceAlt.value > 0",
                        "onClicked": "{ _fenceAlt.value = enableCheckBoxChecked ? 100 : 0 }"
                    }
                }
            ]
        },
        {
            "title": "Return to launch settings",
            "keywords": [
                "rtl",
                "return home",
                "return to launch",
                "loiter",
                "land",
                "altitude"
            ],
            "image": "/qmlimages/ReturnToHomeAltitudeCopter.svg",
            "controls": [
                {
                    "param": "RTL_RETURN_ALT",
                    "label": "Climb to altitude of"
                },
                {
                    "param": "RTL_LAND_DELAY",
                    "label": "Return to launch, then:",
                    "control": "radiogroup",
                    "options": [
                        {
                            "label": "Land immediately",
                            "value": "_rtlLandDelayParamValueLandImmediately",
                            "checked": "_rtlLandDelay.value === _rtlLandDelayParamValueLandImmediately"
                        },
                        {
                            "label": "Loiter and do not land",
                            "value": "_rtlLandDelayParamValueLoiterIndefinitely",
                            "checked": "_rtlLandDelay.value < _rtlLandDelayParamValueLandImmediately"
                        },
                        {
                            "label": "Loiter and land after specified time",
                            "value": "_rtlLandDelayParamValueLoiterDefault",
                            "checked": "_rtlLandDelay.value > _rtlLandDelayParamValueLandImmediately"
                        }
                    ]
                },
                {
                    "param": "RTL_LAND_DELAY",
                    "label": "Loiter time",
                    "enableWhen": "_rtlLandDelay.value > _rtlLandDelayParamValueLandImmediately"
                },
                {
                    "param": "RTL_DESCEND_ALT",
                    "label": "Loiter altitude",
                    "enableWhen": "_rtlLandDelay.value !== _rtlLandDelayParamValueLandImmediately"
                }
            ]
        },
        {
            "title": "Land Mode Settings",
            "keywords": [
                "landing",
                "descent",
                "disarm",
                "touchdown"
            ],
            "image": "/qmlimages/LandModeCopter.svg",
            "controls": [
                {
                    "param": "MPC_LAND_SPEED",
                    "label": "Landing descent rate",
                    "optional": true,
                    "showWhen": "_landSpeedMCExists"
                },
                {
                    "param": "COM_DISARM_LAND",
                    "label": "Disarm after",
                    "control": "slider",
                    "sliderMin": 0,
                    "sliderMax": 10,
                    "enableCheckbox": {
                        "checked": "_disarmLandDelay.value > 0",
                        "onClicked": "{ _disarmLandDelay.value = enableCheckBoxChecked ? 2 : 0 }"
                    }
                }
            ]
        }
    ]
}
