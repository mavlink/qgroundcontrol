        <file alias="QGroundControl/MainWindow.qml">override/qml/MainWindow.qml</file>

        <file alias="QGroundControl/FlightDisplay/FlyViewVideo.qml">override/qml/QGroundControl/FlightDisplay/FlyViewVideo.qml</file>
        <file alias="QGroundControl/FlightDisplay/FlyViewTopRightColumnLayout.qml">override/qml/QGroundControl/FlightDisplay/FlyViewTopRightColumnLayout.qml</file>
        <file alias="QGroundControl/FlightDisplay/FlyViewMap.qml">override/qml/QGroundControl/FlightDisplay/FlyViewMap.qml</file>
        <file alias="QGroundControl/FlightDisplay/FlyViewCustomLayer.qml">override/qml/QGroundControl/FlightDisplay/FlyViewCustomLayer.qml</file>
