<RCC>
    <qresource prefix="/custom/img">
        <file alias="FoxFourTextLogo_light.svg">res/Images/FoxFourTextLogo_light.svg</file>
        <file alias="FoxFourTextLogo_dark.svg">res/Images/FoxFourTextLogo_dark.svg</file>
        <file alias="keyboard.svg">res/Images/keyboard.svg</file>
        <file alias="eye-1.svg">res/Images/eye-opened.svg</file>
        <file alias="eye-0.svg">res/Images/eye-closed.svg</file>
    </qresource>
    <qresource prefix="/Custom/res">
        <file alias="TrashDelete.svg">res/Images/TrashDelete.svg</file>
    </qresource>
    <qresource prefix="/Custom/qmlimages">
        <file alias="PaperPlane.svg">res/Images/CustomVehicleIcon.svg</file>
    </qresource>
    <qresource prefix="/Custom/qml">
        <file alias="QGroundControl/AppSettings/VideoSettings.qml">override/qml/QGroundControl/AppSettings/VideoSettings.qml</file>
