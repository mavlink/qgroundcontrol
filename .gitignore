# ==============================================================================
# QGroundControl - Git Ignore Patterns
# ==============================================================================

# ------------------------------------------------------------------------------
# IDEs & Editors
# ------------------------------------------------------------------------------
.idea/
.qt/
.qtcreator/
.fleet/
.vs/
.settings/
.codex/

# VS Code - track .default files, ignore personal overrides
.vscode/*
!.vscode/extensions.json
!.vscode/*.default.json

# Editor temp/backup files
*.swp
*~
*~.skp
*.autosave
tags

# ------------------------------------------------------------------------------
# Build System & CMake
# ------------------------------------------------------------------------------
build*/
!.github/actions/build*/
cmake-build-*/
out/
CMakeFiles
CMakeLists.txt.user*
CMakeUserPresets.json
compile_commands.json
cpm_modules
.cache/
.ccache/

# CTest working files created in the source tree when tests run
Testing/

# ------------------------------------------------------------------------------
# Qt Generated Files
# ------------------------------------------------------------------------------
*_qmlcache.qrc
qrc_*.cpp
moc_*
ui_*
*.moc
*.prl
*.qm
.qmlls.ini

# ------------------------------------------------------------------------------
# Compiled Objects & Binaries
# ------------------------------------------------------------------------------
*.o
*.Debug
*.Release
*.app
*.exe
*.idb
*.pdb
tmp/
obj/
debug/
release/
/qgroundcontrol
bin/*.exe
bin/*.txt
bin/mac

# Libraries & dynamic/static objects
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll

# Build tool artifacts
*.ninja
.ninja_log
build.ninja

# Packaging & distribution
*.dmg
*.deb
*.rpm
*.AppImage
*.apk
*.aab
*.ipa

# ------------------------------------------------------------------------------
# Platform-Specific
# ------------------------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows - Visual Studio
*.vcproj
*.vcxproj*
*.sln
*.suo
*.ncb
*.sdf
*.ipch
*.opensdf
*.uhf.txt

# iOS
ios/iOSForAppStore-Info.plist

# Android
android/local.properties
.gradle/
*.class
# GStreamer plugin Java + fonts/CA assets copied in by the copyjavasource_<abi> /
# copyfontsres_<abi> / copycacertificatesres_<abi> CMake targets
# (cmake/GStreamer/platform/Android.cmake) at build time — version-matched, regenerated.
android/src/org/freedesktop/
android/assets/fontconfig/
android/assets/ssl/

# Linux
*.nfs

# ------------------------------------------------------------------------------
# Dependencies & Third Party
# ------------------------------------------------------------------------------
# Node.js (vitepress for user guide)
node_modules/
docs/.vitepress/cache/
docs/.vitepress/dist/
docs/api/

# Python
*.pyc
__pycache__/

# ------------------------------------------------------------------------------
# Runtime & Logs
# ------------------------------------------------------------------------------
*.log

# Code coverage
*.gcov
*.gcda
*.gcno
*.coverage

# ------------------------------------------------------------------------------
# Vagrant
# ------------------------------------------------------------------------------
.vagrant/
Qt*-linux*.tar.*

# ------------------------------------------------------------------------------
# Local Development Tools
# ------------------------------------------------------------------------------

# AI Assistants
.claude/
.gemini/
.geminiignore
.cursorignore

# Python tooling caches
.ruff_cache/
.pytest_cache/
.import_linter_cache/
.venv/

# Vale prose linter (downloaded via `vale sync`)
.github/styles/

# direnv / version managers
.envrc
.direnv/
.tool-versions
.python-version
!tools/.python-version
