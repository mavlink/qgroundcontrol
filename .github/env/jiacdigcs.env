# JIACDIGCS Build Environment Configuration
# This file contains environment variables and settings for JIACDIGCS builds

# Application Information
QGC_APP_NAME=JIACDIGCS
QGC_ORG_NAME=JIACDIGCS
QGC_ORG_DOMAIN=jiacdigcs.com
QGC_PACKAGE=org.jiacdigcs.swarm

# Build Configuration
QGC_BUILD_TYPE=Release
QGC_BUILD_SWARM=ON
QGC_BUILD_FIRMWARE=OFF
QGC_BUILD_GST=ON

# Qt Configuration
QT_VERSION_MAJOR=6
QT_VERSION_MINOR=10
QT_VERSION_PATCH=3
QT_VERSION=$QT_VERSION_MAJOR.$QT_VERSION_MINOR.$QT_VERSION_PATCH

# Platform-specific settings
# Windows
WINSDK_DIR=C:/Program Files (x86)/Windows Kits/10/include/10.0.22621.0

# macOS/iOS
MACOS_MIN_SDK=15.0
IOS_MIN_SDK=15.0

# Android
ANDROID_NDK_VERSION=27b
ANDROID_SDK_VERSION=35
ANDROID_MIN_SDK=24

# Build Artifacts
ARTIFACT_PREFIX=jiacdigcs
BUILD_OUTPUT_DIR=build_output