{
    // Editor settings
    "editor.formatOnSave": false,
    "editor.rulers": [120],
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,

    // File associations
    "files.associations": {
        "*.qml": "qml",
        "*.SettingsGroup.json": "json",
        "*.FactMetaData.json": "json",
        "CMakePresets.json": "jsonc"
    },

    // Exclude from search/watch
    "files.watcherExclude": {
        "**/build/**": true,
        "**/.cache/**": true
    },
    "search.exclude": {
        "**/build": true,
        "**/.cache": true,
        "**/libs": true
    },

    // C++ settings
    "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",
    "C_Cpp.codeAnalysis.clangTidy.enabled": true,
    "C_Cpp.codeAnalysis.clangTidy.useBuildPath": true,
    "C_Cpp.formatting.clangFormatStyle": "file",
    "C_Cpp.default.cppStandard": "c++20",

    // CMake settings
    "cmake.configureOnOpen": true,
    "cmake.buildDirectory": "${workspaceFolder}/build",
    "cmake.generator": "Ninja",
    "cmake.parallelJobs": 0,

    // clangd settings (if using clangd instead of ms-vscode.cpptools)
    "clangd.arguments": [
        "--background-index",
        "--clang-tidy",
        "--header-insertion=never",
        "--completion-style=detailed",
        "--function-arg-placeholders=false"
    ],

    // QML settings
    "qml.format.enabled": true,

    // Python settings (for tools)
    "python.defaultInterpreterPath": "python3",

    // Spell checker
    "[markdown]": {
        "editor.wordWrap": "on"
    },

    // Git settings
    "git.ignoreLimitWarning": true
}
