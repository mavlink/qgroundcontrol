{
  "json.schemas": [
    {
      "fileMatch": ["**/FactGroups/*Fact.json"],
      "url": "./src/FactSystem/factmetadata.schema.json"
    }
  ],
  "C_Cpp.default.cppStandard": "c++20",
  "C_Cpp.formatting.clangFormatStyle": "file",
  "C_Cpp.intelliSenseEngine": "disabled",
  "[markdown]": {
    "editor.wordWrap": "on"
  },
  "clangd.arguments": [
    "--background-index",
    "--clang-tidy",
    "--header-insertion=never",
    "--completion-style=detailed",
    "--function-arg-placeholders=false"
  ],
  "cmake.buildDirectory": "${workspaceFolder}/build",
  "cmake.configureOnOpen": false,
  "cmake.generator": "Ninja",
  "editor.formatOnSave": false,
  "editor.insertSpaces": true,
  "editor.rulers": [
    120
  ],
  "[python]": {
    "editor.rulers": [
      100
    ]
  },
  "editor.tabSize": 4,
  "files.associations": {
    "*.FactMetaData.json": "json",
    "*.SettingsGroup.json": "json",
    "*.qml": "qml",
    "CMakePresets.json": "jsonc"
  },
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "files.watcherExclude": {
    "**/.cache/**": true,
    "**/build/**": true
  },
  "git.ignoreLimitWarning": true,
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv",
  "qml.format.enabled": true,
  "qt-qml.qmlls.useQmllsFromEnvironment": true,
  "qt-qml.qmlls.customArgs": [
    "--no-cmake-calls",
    "--build-dir",
    "${workspaceFolder}/build"
  ],
  "search.exclude": {
    "**/.cache": true,
    "**/build": true,
    "**/libs": true
  }
}
