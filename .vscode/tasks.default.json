{
  "inputs": [
    {
      "description": "CTest test name or regular expression (e.g., FactSystemTest)",
      "id": "testClass",
      "type": "promptString"
    }
  ],
  "tasks": [
    {
      "args": [
        "configure"
      ],
      "command": "just",
      "group": "build",
      "label": "CMake: Configure (Debug)",
      "options": {
        "env": {
          "BUILD_TYPE": "Debug"
        }
      },
      "problemMatcher": [],
      "type": "shell"
    },
    {
      "args": [
        "configure"
      ],
      "command": "just",
      "group": "build",
      "label": "CMake: Configure (Release)",
      "options": {
        "env": {
          "BUILD_TYPE": "Release"
        }
      },
      "problemMatcher": [],
      "type": "shell"
    },
    {
      "args": [
        "build"
      ],
      "command": "just",
      "group": {
        "isDefault": true,
        "kind": "build"
      },
      "label": "CMake: Build",
      "problemMatcher": "$gcc",
      "type": "shell"
    },
    {
      "args": [
        "clean"
      ],
      "command": "just",
      "group": "build",
      "label": "CMake: Clean",
      "problemMatcher": [],
      "type": "shell"
    },
    {
      "args": [
        "test"
      ],
      "command": "just",
      "dependsOn": "CMake: Build",
      "group": {
        "isDefault": true,
        "kind": "test"
      },
      "label": "Run Tests",
      "problemMatcher": [],
      "type": "shell"
    },
    {
      "args": [
        "--test-dir",
        "build",
        "--output-on-failure",
        "-R",
        "${input:testClass}"
      ],
      "command": "ctest",
      "dependsOn": "CMake: Build",
      "group": "test",
      "label": "Run Specific Test",
      "problemMatcher": [],
      "type": "shell"
    },
    {
      "args": [
        "format"
      ],
      "command": "just",
      "group": "none",
      "label": "Format: Check Changed Files",
      "problemMatcher": [],
      "type": "shell"
    },
    {
      "args": [
        "format-fix"
      ],
      "command": "just",
      "group": "none",
      "label": "Format: Fix Changed Files",
      "problemMatcher": [],
      "type": "shell"
    },
    {
      "args": [
        "analyze"
      ],
      "command": "just",
      "group": "none",
      "label": "Static Analysis",
      "problemMatcher": "$gcc",
      "type": "shell"
    },
    {
      "args": [
        "lint"
      ],
      "command": "just",
      "group": "none",
      "label": "Pre-commit: Run All",
      "problemMatcher": [],
      "type": "shell"
    },
    {
      "args": [
        "${workspaceFolder}/tools/translations/qgc_lupdate.py"
      ],
      "command": "python3",
      "group": "none",
      "label": "Update Translations",
      "problemMatcher": [],
      "type": "shell"
    }
  ],
  "version": "2.0.0"
}
