# ---------- Base image ----------
FROM ubuntu:24.04

# ---------- Non-interactive APT ----------
ENV DEBIAN_FRONTEND=noninteractive

# ---------- System packages & locale ----------
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        locales \
        git \
        ninja-build \
        cmake \
        ca-certificates \
        build-essential \
        curl \
        unzip \
        python3 \
        pipx && \
    sed -i 's/^# *\(en_US.UTF-8 UTF-8\)/\1/' /etc/locale.gen && \
    locale-gen && \
    update-locale LANG=en_US.UTF-8 && \
    rm -rf /var/lib/apt/lists/*

# Build-time Python deps for CMake-invoked generators (jinja2 for
# settings_qml/config_qml). Synced from tools/pyproject.toml [scripts] so the
# dep list stays unified with developer/runner envs. Pinned via
# Python3_EXECUTABLE in entrypoint.sh.
COPY --from=ghcr.io/astral-sh/uv:0.11.12 /uv /usr/local/bin/uv
COPY tools/pyproject.toml tools/uv.lock /tmp/qgc-tools/
# Smoke-check importability of every dep in tools/pyproject.toml [scripts] so a
# missing/broken wheel fails the build instead of crashing during CMake generators.
RUN uv venv --seed /opt/qgc-venv --python python3 && \
    VIRTUAL_ENV=/opt/qgc-venv uv sync \
        --project /tmp/qgc-tools \
        --extra scripts --extra qt \
        --no-install-project \
        --frozen --active --no-cache && \
    /opt/qgc-venv/bin/python -c "import jinja2, httpx, defusedxml" && \
    /opt/qgc-venv/bin/aqt --help >/dev/null && \
    rm -rf /tmp/qgc-tools /usr/local/bin/uv
ENV PATH="/opt/qgc-venv/bin:${PATH}"
ENV LANG=en_US.UTF-8 \
    LANGUAGE=en_US:en \
    LC_ALL=en_US.UTF-8

# ---------- Bring in the helper scripts and config ----------
# install_dependencies/_common.py imports tools/common/build_config via parents[2] →
# `/tmp/qt/..` must contain `common/`, so mirror tools/ layout under /tmp/.
COPY .github/build-config.json /tmp/qt/
COPY tools/setup/install_dependencies/ /tmp/qt/install_dependencies/
COPY tools/setup/read_config.py /tmp/qt/
COPY tools/common/ /tmp/common/
RUN python3 /tmp/qt/install_dependencies --platform debian && \
    QT_VERSION=$(python3 /tmp/qt/read_config.py --get qt_version) && \
    QT_MODULES=$(python3 /tmp/qt/read_config.py --get qt_modules) && \
    mkdir -p /opt/Qt && \
    aqt_install() { \
        for attempt in 1 2 3; do \
            /opt/qgc-venv/bin/aqt install-qt linux desktop "$1" "$2" -O /opt/Qt -m ${QT_MODULES} && return 0; \
            echo "==> aqt $2 attempt ${attempt}/3 failed; retrying after ${attempt}0s" >&2; \
            sleep "${attempt}0"; \
        done; \
        return 1; \
    } && \
    aqt_install "${QT_VERSION}" linux_gcc_64 && \
    echo "export QT_ROOT_DIR=/opt/Qt/${QT_VERSION}/gcc_64" >> /etc/profile.d/qt.sh && \
    echo 'export PATH=$QT_ROOT_DIR/bin:$PATH' >> /etc/profile.d/qt.sh && \
    chmod +x /etc/profile.d/qt.sh && \
    rm -rf /var/lib/apt/lists/* && \
    rm -rf /tmp/qt /tmp/common

# Source qt.sh in bash login shells; for non-login, find Qt dynamically
SHELL ["/bin/bash", "-lc"]

# ---------- Git safe directory (avoids “detected dubious ownership”) ----------
RUN git config --global --add safe.directory /project/source

# ---------- Work directories ----------
# They will be mounted as volumes when you run the container
RUN mkdir -p /project/source /project/build
WORKDIR /project/build

# ---------- Entrypoint ----------
COPY deploy/docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/bin/bash", "-l", "/entrypoint.sh"]
CMD ["Release"]
