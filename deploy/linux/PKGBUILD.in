# Maintainer: Dronecode <dev@dronecode.org>
# Generated by CMake from this template (configure_file in CreateArchPackage.cmake);
# edit the .in, never the copy under the build tree. Packages QGC's pre-built
# install tree into .pkg.tar.zst (Arch has no CPack); a smoke artifact, not a
# published distributable.
# shellcheck shell=bash
# shellcheck disable=SC2034,SC2154  # makepkg consumes these globals / sets $pkgdir
pkgname=qgroundcontrol
# Version is resolved by CMake from git-describe; makepkg forbids '-' in pkgver.
pkgver=@QGC_ARCH_PKGVER@
pkgrel=1
pkgdesc="Ground Control Station for MAVLink-based UAVs"
arch=('x86_64' 'aarch64')
url="@PROJECT_HOMEPAGE_URL@"
license=('Apache' 'GPL3')

# Hand-maintained runtime deps: DEB derives these via dpkg-shlibdeps and RPM via
# rpmbuild AUTOREQ, but makepkg here runs --nodeps with no equivalent, so this is
# the one packaging dep list that drifts. Sourced from QGC_ARCH_DEPENDS in
# CreateArchPackage.cmake — keep it in sync there, not here.
depends=(@QGC_ARCH_DEPENDS@)

# No sources / no compilation: package() installs the already-built tree.
options=('!strip' '!debug')

package() {
    DESTDIR="${pkgdir}" cmake --install "@CMAKE_BINARY_DIR@" \
        --component Unspecified --prefix /usr
}
