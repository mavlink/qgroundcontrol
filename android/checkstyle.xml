<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
  Checkstyle config for QGroundControl first-party Android Java (org.mavlink.qgroundcontrol.*).

  Scope: high-signal, style-AGNOSTIC correctness/hygiene checks only. We deliberately omit
  whitespace/indentation/line-length/brace-placement rules: the repo targets 120 columns and uses
  intentional alignment (aligned switch arms, single-line bridge overrides) that those checks fight.
  google-java-format is NOT adopted — it is locked to 100-column AOSP/80-column Google and would
  reflow every file. This config is enforced by the `checkstyle` pre-commit hook over first-party
  sources; third-party Qt/SDL/GStreamer Java is excluded there, not here.
-->
<module name="Checker">
    <property name="severity" value="error"/>
    <property name="charset" value="UTF-8"/>
    <property name="fileExtensions" value="java"/>

    <module name="TreeWalker">
        <!-- Imports: dead/duplicate/star -->
        <module name="UnusedImports">
            <property name="processJavadoc" value="true"/>
        </module>
        <module name="RedundantImport"/>
        <module name="AvoidStarImport"/>

        <!-- Correctness traps -->
        <module name="EqualsHashCode"/>
        <module name="CovariantEquals"/>
        <module name="EqualsAvoidNull"/>
        <module name="StringLiteralEquality"/>
        <module name="MissingOverride"/>
        <module name="FallThrough"/>
        <module name="MissingSwitchDefault"/>
        <module name="DefaultComesLast"/>
        <module name="EmptyStatement"/>
        <module name="EmptyBlock">
            <property name="option" value="text"/>
            <property name="tokens" value="LITERAL_TRY,LITERAL_FINALLY,LITERAL_IF,LITERAL_ELSE,LITERAL_FOR,LITERAL_WHILE,LITERAL_DO,STATIC_INIT,INSTANCE_INIT"/>
        </module>
        <module name="SimplifyBooleanReturn"/>

        <!-- Readability hygiene that does not reflow code -->
        <module name="ModifierOrder"/>
        <module name="UpperEll"/>
        <module name="ArrayTypeStyle"/>
    </module>
</module>
