{
  "version": 6,
  "include": ["common.json"],
  "configurePresets": [
    {
      "name": "windows-base",
      "hidden": true,
      "generator": "Ninja",
      "inherits": ["ccache"],
      "toolchainFile": "$penv{QT_ROOT_DIR}/lib/cmake/Qt6/qt.toolchain.cmake",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "Windows",
      "displayName": "Windows x64 Release",
      "inherits": ["release", "windows-base"],
      "binaryDir": "${sourceDir}/build/Windows"
    },
    {
      "name": "Windows-debug",
      "displayName": "Windows x64 Debug",
      "inherits": ["debug", "windows-base"],
      "binaryDir": "${sourceDir}/build/Windows-debug"
    },
    {
      "name": "Windows-arm64",
      "displayName": "Windows ARM64 Release",
      "inherits": ["release", "windows-base"],
      "binaryDir": "${sourceDir}/build/Windows-arm64",
      "cacheVariables": {
        "QT_HOST_PATH": "$penv{QT_HOST_PATH}"
      }
    },
    {
      "name": "Windows-arm64-debug",
      "displayName": "Windows ARM64 Debug",
      "inherits": ["debug-no-tests", "windows-base"],
      "binaryDir": "${sourceDir}/build/Windows-arm64-debug",
      "cacheVariables": {
        "QT_HOST_PATH": "$penv{QT_HOST_PATH}"
      }
    }
  ],
  "buildPresets": [
    { "name": "Windows", "configurePreset": "Windows", "configuration": "Release", "inherits": ["build-defaults"] },
    { "name": "Windows-debug", "configurePreset": "Windows-debug", "configuration": "Debug", "inherits": ["build-defaults"] },
    { "name": "Windows-arm64", "configurePreset": "Windows-arm64", "configuration": "Release", "inherits": ["build-defaults"] },
    { "name": "Windows-arm64-debug", "configurePreset": "Windows-arm64-debug", "configuration": "Debug", "inherits": ["build-defaults"] }
  ],
  "testPresets": [
    { "name": "Windows-debug", "configurePreset": "Windows-debug", "configuration": "Debug", "inherits": ["test-defaults"] }
  ],
  "packagePresets": [
    { "name": "Windows", "configurePreset": "Windows", "configurations": ["Release"] },
    { "name": "Windows-arm64", "configurePreset": "Windows-arm64", "configurations": ["Release"] }
  ],
  "workflowPresets": [
    {
      "name": "Windows",
      "steps": [
        { "type": "configure", "name": "Windows" },
        { "type": "build", "name": "Windows" },
        { "type": "package", "name": "Windows" }
      ]
    },
    {
      "name": "Windows-debug",
      "steps": [
        { "type": "configure", "name": "Windows-debug" },
        { "type": "build", "name": "Windows-debug" },
        { "type": "test", "name": "Windows-debug" }
      ]
    },
    {
      "name": "Windows-arm64",
      "steps": [
        { "type": "configure", "name": "Windows-arm64" },
        { "type": "build", "name": "Windows-arm64" },
        { "type": "package", "name": "Windows-arm64" }
      ]
    },
    {
      "name": "Windows-arm64-debug",
      "steps": [
        { "type": "configure", "name": "Windows-arm64-debug" },
        { "type": "build", "name": "Windows-arm64-debug" }
      ]
    }
  ]
}
