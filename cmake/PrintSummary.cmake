list(LENGTH QGC_HARDENING_LINK_FLAGS _qgc_n_harden_link)
if(_qgc_n_harden_cxx GREATER 0 OR _qgc_n_harden_link GREATER 0)
    message(STATUS "  Hardening:          ${_qgc_n_harden_cxx} compile + ${_qgc_n_harden_link} link flag(s), non-Debug")
else()
    message(STATUS "  Hardening:          OFF")
endif()
