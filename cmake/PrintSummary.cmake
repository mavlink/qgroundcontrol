# QGroundControl Build Configuration Summary

string(TIMESTAMP QGC_CONFIGURE_TIME "%Y-%m-%d %H:%M:%S %Z")

function(_qgc_kv _label _value)
    if(NOT "${_value}" STREQUAL "")
        message(STATUS "  ${_label}${_value}")
    endif()
endfunction()

macro(OptionOutput _label)
    if(${ARGN})
        set(_val "ON")
    else()
        set(_val "OFF")
    endif()
    message(STATUS "  ${_label}: ${_val}")
endmacro()

message(STATUS "")
message(STATUS "==================================================================")
message(STATUS "QGroundControl Build Configuration Summary")
message(STATUS "  Reporting a build problem? Copy this entire block into your issue")
message(STATUS "  at https://github.com/mavlink/qgroundcontrol/issues")
message(STATUS "==================================================================")

